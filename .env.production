# Docker 生产环境配置

# 数据库
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=inquiry
DB_USER=inquiry
DB_PASSWORD=change_me_in_production

# Redis
REDIS_ENABLED=true
REDIS_PASSWORD=change_me_redis_password

# JWT
JWT_SECRET=change_me_to_random_string_at_least_32_chars

# Firecrawl (可选)
FIRECRAWL_API_KEY=

# 飞书 Webhook (可选)
FEISHU_WEBHOOK=

# 端口映射
# PostgreSQL: 5432
# Redis: 6379
# API: 8000
# UI: 7860
